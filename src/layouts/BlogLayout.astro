---
import "../styles/global.css";
import "@fontsource/space-grotesk";
import "@fontsource/ibm-plex-mono";
import SideNav from "../components/SideNav.astro";
import { ClientRouter } from "astro:transitions";
import TwitterMeta from "../components/meta/TwitterMeta.astro";
import OpenGraphMeta from "../components/meta/OpenGraphMeta.astro";

type Props = {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  lang?: string;
  structuredData?: string;
};

const {
  title = "William Leemans",
  description = "Salut ! Moi c'est William. Belge, entrepreneur, architecte logiciel passionné et CTO chez Jetdev. J'aime construire des systèmes, mentorer des développeurs et créer des produits utiles.",
  ogImage = "/og/default.jpg",
  noindex = false,
  lang = "fr",
} = Astro.props;

const nav = [
  { label: "Home", href: "/" },
  { label: "Blog", href: "/blog" },
  { label: "Now", href: "/now" },
];

const site = Astro.site?.toString() ?? "https://williamleemans.me";
const canonical = new URL(Astro.url.pathname, site).toString();
---

<!doctype html>
<html
  lang={lang}
  class="h-full scroll-smooth"
  transition:name="root"
  transition:animate="initial"
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link
      rel="alternate"
      type="application/rss+xml"
      title="William Leemans"
      href={new URL("rss.xml", Astro.site)}
    />

    <!-- Privacy-friendly analytics by Plausible -->
    <script async src="https://plausible.io/js/pa-QovbWITZik5-tHtN9XgGD.js"></script>
    <script>
      window.plausible=window.plausible||function(){(plausible.q=plausible.q||[]).push(arguments)},plausible.init=plausible.init||function(i){plausible.o=i||{}};
      plausible.init()
    </script>

    <!-- Robots -->
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow"}
    />

    <OpenGraphMeta
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
    />

    <TwitterMeta title={title} description={description} image={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <ClientRouter />

    <script is:inline>
      function applyTheme() {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const dark = stored === 'dark' || (!stored && prefersDark);
        document.documentElement.classList.toggle('dark', dark);
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
  </head>
  <body class="bg-primary-100 dark:bg-[#1a1a1a] dark:text-primary-100 h-full min-h-screen antialiased">

    <!-- Dot grid background -->
    <div class="blog-dot-grid" aria-hidden="true"></div>

    <!-- Content area -->
    <div class="flex min-h-screen">
      <SideNav items={nav} />

      <main class="w-full md:ml-16">
        <div class="h-14 md:h-0"></div>
        <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 md:px-10 md:py-12 lg:py-16 relative">
          <slot />
        </div>
      </main>
    </div>

    <script>
      function initCircuitAnimations() {
        // Draw-in animation for all traces using their actual path length
        const traces = document.querySelectorAll<SVGPathElement>('.circuit-trace');
        let lastEnd = 0.05;
        traces.forEach((path) => {
          const length = path.getTotalLength();
          // Duration scales with path length: ~0.4s for short, ~1s for long
          const dur = Math.max(0.35, Math.min(length / 180, 1.0));
          path.style.strokeDasharray = String(length);
          path.style.strokeDashoffset = String(length);
          path.style.animation = `circuit-draw ${dur.toFixed(2)}s cubic-bezier(0.4, 0, 0.2, 1) ${lastEnd.toFixed(2)}s forwards`;
          lastEnd += dur * 0.6; // overlap slightly so they chain together
        });

        // Fade in dots, rects, and labels after the traces have mostly drawn
        const statics = document.querySelectorAll<Element>('.circuit-dot, .circuit-rect, .circuit-label');
        statics.forEach((el, i) => {
          (el as HTMLElement).style.opacity = '0';
          (el as HTMLElement).style.animation = `circuit-appear 0.3s ease-out ${(lastEnd - 0.1 + i * 0.07).toFixed(2)}s forwards`;
        });
      }

      document.addEventListener('astro:page-load', initCircuitAnimations);
    </script>
  </body>
</html>

<style>
  /* Dot grid — full-page fixed layer */
  .blog-dot-grid {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: radial-gradient(circle, rgba(107, 107, 107, 0.13) 1px, transparent 1px);
    background-size: 20px 20px;
  }

  :global(.dark) .blog-dot-grid {
    background-image: radial-gradient(circle, rgba(250, 250, 250, 0.06) 1px, transparent 1px);
  }

  @keyframes circuit-draw {
    to { stroke-dashoffset: 0; }
  }

  @keyframes circuit-appear {
    to { opacity: 1; }
  }

  :global(@media (prefers-reduced-motion: reduce)) {
    :global(.circuit-trace) {
      animation: none !important;
      stroke-dashoffset: 0 !important;
    }
    :global(.circuit-dot),
    :global(.circuit-rect),
    :global(.circuit-label) {
      animation: none !important;
      opacity: 1 !important;
    }
  }
</style>
