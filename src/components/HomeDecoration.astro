---
// No props — purely visual, no contextual data on the home page.
---

<!--
  Grid-aligned circuit decoration for the home page header.
  Two parallel traces (upper y=20, lower y=40) connected by vias.
  Arc apexes on the lower trace kiss the upper trace at y=20.

  y=20  ──|──────────────────●────────────────────────────────●────|──
           tick(20)         via(130)                          via(300) tick(340)
  y=40  ──────●══╮══●──────────────────────●══╮══●──────────────────
              arc1(60→100)               arc2(220→260)
-->
<div class="hidden md:block mt-5" aria-hidden="true">
  <svg width="380" height="50" viewBox="0 0 380 50" fill="none" class="decoration">

    <!-- Upper trace (y=20): full width dashed -->
    <path d="M 0 20 L 380 20" stroke="currentColor" stroke-width="1" stroke-dasharray="3 6" class="circuit-trace" />

    <!-- Ticks on upper trace at x=20, x=160, x=340 -->
    <path d="M 20 16 L 20 24"   stroke="currentColor" stroke-width="0.75" class="circuit-trace" />
    <path d="M 160 16 L 160 24" stroke="currentColor" stroke-width="0.75" class="circuit-trace" />
    <path d="M 340 16 L 340 24" stroke="currentColor" stroke-width="0.75" class="circuit-trace" />

    <!-- Lower trace (y=40): dashed segments between arcs -->
    <path d="M 0 40 L 60 40"    stroke="currentColor" stroke-width="1" stroke-dasharray="3 6" class="circuit-trace" />
    <path d="M 100 40 L 220 40" stroke="currentColor" stroke-width="1" stroke-dasharray="3 6" class="circuit-trace" />
    <path d="M 260 40 L 380 40" stroke="currentColor" stroke-width="1" stroke-dasharray="3 6" class="circuit-trace" />

    <!-- Arc 1: x=60→100, radius 20, apex at (80,20) — sweep 0 = upward dome -->
    <path d="M 60 40 A 20 20 0 0 0 100 40" stroke="currentColor" stroke-width="1" class="circuit-trace" />

    <!-- Arc 2: x=220→260, radius 20, apex at (240,20) -->
    <path d="M 220 40 A 20 20 0 0 0 260 40" stroke="currentColor" stroke-width="1" class="circuit-trace" />

    <!-- Vias: vertical connections between traces at x=130 and x=300 -->
    <path d="M 130 20 L 130 40" stroke="currentColor" stroke-width="1" class="circuit-trace" />
    <path d="M 300 20 L 300 40" stroke="currentColor" stroke-width="1" class="circuit-trace" />

    <!-- Arc 1 junction dots -->
    <circle cx="60"  cy="40" r="2"   fill="currentColor" class="circuit-dot" />
    <circle cx="100" cy="40" r="2"   fill="currentColor" class="circuit-dot" />
    <circle cx="80"  cy="20" r="1.5" fill="currentColor" class="circuit-dot" />

    <!-- Arc 2 junction dots -->
    <circle cx="220" cy="40" r="2"   fill="currentColor" class="circuit-dot" />
    <circle cx="260" cy="40" r="2"   fill="currentColor" class="circuit-dot" />
    <circle cx="240" cy="20" r="1.5" fill="currentColor" class="circuit-dot" />

    <!-- Via junction dots -->
    <circle cx="130" cy="20" r="1.5" fill="currentColor" class="circuit-dot" />
    <circle cx="130" cy="40" r="1.5" fill="currentColor" class="circuit-dot" />
    <circle cx="300" cy="20" r="1.5" fill="currentColor" class="circuit-dot" />
    <circle cx="300" cy="40" r="1.5" fill="currentColor" class="circuit-dot" />
  </svg>
</div>

<style>
  .decoration {
    color: rgba(107, 107, 107, 0.75);
  }

  :global(.dark) .decoration {
    color: rgba(250, 250, 250, 0.35);
  }

  .circuit-dot {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .circuit-dot {
      opacity: 1 !important;
      animation: none !important;
    }
  }
</style>
