---
// No props — purely visual footer decoration for the home page.
---

<!--
  Grid-aligned closing trace for the home page.
  Single dashed trace with ticks and a short upward branch.

  y=4   ────────────────────────────────|─────────────────────
                                     branch-top(200)
  y=20  ──|─────────────────────────────────────────────────|──
          tick(40)                       tick(160)         tick(260)
-->
<div class="hidden md:block mt-6" aria-hidden="true">
  <svg width="300" height="30" viewBox="0 0 300 30" fill="none" class="decoration">

    <!-- Dashed trace: 0 → 300 -->
    <path d="M 0 20 L 300 20" stroke="currentColor" stroke-width="1" stroke-dasharray="3 6" class="circuit-trace" />

    <!-- Ticks at x=40, x=160, x=260 -->
    <path d="M 40 16 L 40 24"   stroke="currentColor" stroke-width="0.75" class="circuit-trace" />
    <path d="M 160 16 L 160 24" stroke="currentColor" stroke-width="0.75" class="circuit-trace" />
    <path d="M 260 16 L 260 24" stroke="currentColor" stroke-width="0.75" class="circuit-trace" />

    <!-- Short upward branch at x=200: y=20 → y=4 -->
    <path d="M 200 20 L 200 4"  stroke="currentColor" stroke-width="1" class="circuit-trace" />

    <!-- Branch junction and tip dots -->
    <circle cx="200" cy="20" r="1.75" fill="currentColor" class="circuit-dot" />
    <circle cx="200" cy="4"  r="1.25" fill="currentColor" class="circuit-dot" />
  </svg>
</div>

<style>
  .decoration {
    color: rgba(107, 107, 107, 0.65);
  }

  :global(.dark) .decoration {
    color: rgba(250, 250, 250, 0.28);
  }

  .circuit-dot {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .circuit-dot {
      opacity: 1 !important;
      animation: none !important;
    }
  }
</style>
